{
  "_meta": {"stage": "extraction", "feeds": "E1", "match": "a unit matches if an extracted KU of the same type contains all `terms` (case-insensitive)"},
  "cases": [
    {"id": "ext_refund_policy", "tier": "standard", "split": "test", "kind": "notion_page",
     "content": "Refund Policy\nRefunds within 30 days of purchase are automatically approved.\nRefund requests above $500 require manager sign-off.\nNever refund an order older than 90 days without manager approval.\nNever exceed the original charge amount.\n1. Look up the order by order_id.",
     "expected_units": [
       {"type": "policy_rule", "terms": ["30 day", "auto"], "must_have_span": "30 days"},
       {"type": "policy_rule", "terms": ["$500", "manager"], "must_have_span": "$500"},
       {"type": "policy_rule", "terms": ["never", "90 days"]},
       {"type": "policy_rule", "terms": ["never exceed", "original"]},
       {"type": "procedure_step", "terms": ["look up the order"]}
     ], "expected_absent": false},
    {"id": "ext_refund_slack_decision", "tier": "standard", "split": "test", "kind": "slack_message",
     "content": "Going forward, refunds above $500 require manager sign-off. We made an exception today after manager approval.",
     "expected_units": [
       {"type": "policy_rule", "terms": ["$500", "manager"], "must_have_span": "$500"}
     ], "expected_absent": false},
